FROM rust:1.88-bookworm

RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    curl \
    unzip \
    && rm -rf /var/lib/apt/lists/*

# cargo-watch pour le hot-reload en dev.
# --locked force l'utilisation du Cargo.lock du crate pour eviter
# des resolutions de dependances incompatibles avec cette toolchain.
RUN cargo install cargo-watch --locked

WORKDIR /app

# Le code source est monté en volume — pas de COPY.
# Le cache Cargo est dans un volume nommé pour persister entre les builds.

EXPOSE 3001

CMD ["cargo", "watch", "-x", "run --bin gazflow-back"]
